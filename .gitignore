# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
**/bin/
**/obj/
[Bb]uild-out/
extension/dist/
extension/out/
# engine published into the extension for packaging (generated by `npm run bundle-engine`)
extension/engine/
# LICENSE copied into the extension at package time (generated by `npm run copy-license`)
extension/LICENSE
*.vsix

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
**/node_modules/

# ---------------------------------------------------------------------------
# .NET / Visual Studio (note: extension/.vscode/ is intentionally tracked —
# launch.json drives the F5 dev loop, see CONTRIBUTING.md)
# ---------------------------------------------------------------------------
.vs/
*.user
*.suo

# ---------------------------------------------------------------------------
# Logs, crash dumps, scratch
# ---------------------------------------------------------------------------
*.log
*.stackdump
*.tmp
extension/tmp/
.agent-scratch/

# Engine / e2e render artifacts (regenerated on every run)
/extender-render.png
/menustrip-render.png
/tooltip-render.png
extension/e2e-render.png
engine/bin/**/*.png

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Internal planning notes & local AI tooling (not part of the public repo)
# ---------------------------------------------------------------------------
.claude/
docs/plans/
run-codex.cmd
test_handler_regex.js
