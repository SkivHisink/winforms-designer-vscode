# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
**/bin/
**/obj/
[Bb]uild-out/
extension/dist/
extension/out/
extension/.vscode-test/
.npm-cache-do-not-use/
.dotnet-temp/
.dotnet-home/
.nuget-local/
# CLI --set-tsitems / --set-* edit-preview output (regenerable; never committed)
*.edited.txt
# CLI --save dry-run splice preview (engine/Program.cs writes "<file>.spliced.txt"); regenerable, never committed
*.spliced.txt
# engines published into the extension for packaging (generated by `npm run bundle-engine[-net48]`)
extension/engine/
extension/engine-net48/
# LICENSE / CHANGELOG / THIRD-PARTY-NOTICES copied into the extension at package time (copy-license / copy-changelog / copy-notices)
extension/LICENSE
extension/CHANGELOG.md
extension/THIRD-PARTY-NOTICES.md
*.vsix

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
**/node_modules/

# ---------------------------------------------------------------------------
# .NET / Visual Studio (note: extension/.vscode/ is intentionally tracked —
# launch.json drives the F5 dev loop, see CONTRIBUTING.md)
# ---------------------------------------------------------------------------
.vs/
*.user
*.suo

# ---------------------------------------------------------------------------
# Logs, crash dumps, scratch
# ---------------------------------------------------------------------------
*.log
*.stackdump
*.tmp
extension/tmp/
.agent-scratch/
.codex-tmp/

# Engine / e2e render artifacts (regenerated on every run)
/extender-render.png
/menustrip-render.png
/tooltip-render.png
extension/e2e-render.png
engine/bin/**/*.png
# net48 engine spike render-proof screenshots (not part of the build)
engine-net48/*.png

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Internal planning notes & local AI tooling (not part of the public repo)
# ---------------------------------------------------------------------------
.claude/
docs/plans/
docs/handoffs/
docs/maps/
run-codex.cmd
test_handler_regex.js
