{
  "name": "winforms-designer-vscode",
  "displayName": "WinForms Designer for VS Code",
  "description": "%description%",
  "publisher": "SkivHisink",
  "version": "1.0.0",
  "preview": false,
  "license": "MIT",
  "author": {
    "name": "SkivHisink",
    "url": "https://github.com/SkivHisink"
  },
  "homepage": "https://github.com/SkivHisink/winforms-designer-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkivHisink/winforms-designer-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/SkivHisink/winforms-designer-vscode/issues"
  },
  "qna": "https://github.com/SkivHisink/winforms-designer-vscode/issues",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#2D2D30",
    "theme": "dark"
  },
  "keywords": [
    "winforms",
    "windows forms",
    "c#",
    "csharp",
    "designer",
    "form designer",
    "ui designer",
    "visual designer",
    "gui",
    "forms",
    ".net",
    "dotnet",
    "net10",
    "net9",
    "net framework",
    "net48",
    "devexpress",
    "wysiwyg",
    "drag and drop"
  ],
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "%untrusted.description%"
    },
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "winformsDesigner.designer",
        "displayName": "%editor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.cs"
          }
        ],
        "priority": "option"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "winformsDesigner",
          "title": "%viewsContainers.title%",
          "icon": "media/winforms-activity.svg"
        }
      ]
    },
    "views": {
      "winformsDesigner": [
        {
          "type": "webview",
          "id": "winformsDesigner.panel",
          "name": "%view.name%"
        }
      ]
    },
    "configurationDefaults": {
      "explorer.fileNesting.enabled": true,
      "explorer.fileNesting.patterns": {
        "*.cs": "${capture}.Designer.cs, ${capture}.resx"
      }
    },
    "commands": [
      {
        "command": "winformsDesigner.open",
        "title": "%command.open.title%"
      },
      {
        "command": "winformsDesigner.viewCode",
        "title": "%command.viewCode.title%"
      },
      {
        "command": "winformsDesigner.showProperties",
        "title": "%command.showProperties.title%"
      },
      {
        "command": "winformsDesigner.exportDiagnostics",
        "title": "%command.exportDiagnostics.title%"
      },
      {
        "command": "winformsDesigner.selectControlAssembly",
        "title": "%command.selectControlAssembly.title%",
        "icon": "$(package)"
      },
      {
        "command": "winformsDesigner.editImageListImages",
        "title": "%command.editImageListImages.title%"
      },
      {
        "command": "winformsDesigner.releaseAssembly",
        "title": "%command.releaseAssembly.title%"
      }
    ],
    "keybindings": [
      {
        "command": "winformsDesigner.showProperties",
        "key": "f4",
        "when": "activeCustomEditorId == winformsDesigner.designer"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "winformsDesigner.open",
          "when": "winformsDesigner.canOpen"
        },
        {
          "command": "winformsDesigner.viewCode",
          "when": "activeCustomEditorId == winformsDesigner.designer"
        },
        {
          "command": "winformsDesigner.selectControlAssembly",
          "when": "activeCustomEditorId == winformsDesigner.designer"
        },
        {
          "command": "winformsDesigner.editImageListImages",
          "when": "activeCustomEditorId == winformsDesigner.designer"
        }
      ],
      "editor/title": [
        {
          "command": "winformsDesigner.open",
          "when": "winformsDesigner.canOpen",
          "group": "navigation"
        },
        {
          "command": "winformsDesigner.viewCode",
          "when": "activeCustomEditorId == winformsDesigner.designer",
          "group": "navigation"
        },
        {
          "command": "winformsDesigner.selectControlAssembly",
          "when": "activeCustomEditorId == winformsDesigner.designer",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "winformsDesigner.autoOpenDesigner": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "markdownDescription": "%config.autoOpenDesigner.description%"
        },
        "winformsDesigner.assemblyPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "%config.assemblyPath.description%"
        },
        "winformsDesigner.net48.probeDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "window",
          "markdownDescription": "%config.net48.probeDirectories.description%"
        },
        "winformsDesigner.language": {
          "type": "string",
          "default": "en",
          "scope": "window",
          "enum": [
            "en",
            "ru",
            "zh-cn",
            "fr",
            "de",
            "es",
            "hi"
          ],
          "enumItemLabels": [
            "English",
            "Русский",
            "简体中文",
            "Français",
            "Deutsch",
            "Español",
            "हिन्दी"
          ],
          "markdownEnumDescriptions": [
            "English",
            "Russian — Русский",
            "Chinese (Simplified) — 简体中文",
            "French — Français",
            "German — Deutsch",
            "Spanish — Español",
            "Hindi — हिन्दी"
          ],
          "markdownDescription": "%config.language.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "node dist/e2e.cjs",
    "webview-e2e": "node dist/webview-e2e.cjs",
    "extension-host-e2e": "node ../scripts/run-extension-host-tests.mjs",
    "l10n:parity": "node ../scripts/ci-l10n-parity.mjs",
    "release:preflight": "node ../scripts/release-preflight.mjs",
    "perf:baseline": "node dist/performance-baseline.cjs",
    "bundle-engine": "dotnet publish ../engine -c Release -f net10.0-windows -r win-x64 --self-contained false -o engine",
    "bundle-engine-net48": "dotnet publish ../engine-net48 -c Release -o engine-net48",
    "copy-license": "node -e \"require('fs').copyFileSync('../LICENSE','LICENSE')\"",
    "copy-changelog": "node -e \"require('fs').copyFileSync('../CHANGELOG.md','CHANGELOG.md')\"",
    "copy-notices": "node -e \"require('fs').copyFileSync('../THIRD-PARTY-NOTICES.md','THIRD-PARTY-NOTICES.md')\"",
    "vscode:prepublish": "npm run build && npm run bundle-engine && npm run bundle-engine-net48 && npm run copy-license && npm run copy-changelog && npm run copy-notices"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "vscode-jsonrpc": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "1.84.0",
    "@vscode/test-electron": "3.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
