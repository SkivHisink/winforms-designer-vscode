{
  "name": "winforms-designer-vscode",
  "displayName": "WinForms Designer for VS Code",
  "description": "Visualize and edit WinForms .Designer.cs forms live inside VS Code — a Visual Studio-style designer surface, property grid, toolbox and event wiring, powered by a .NET 9 rendering engine.",
  "publisher": "SkivHisink",
  "version": "0.2.0",
  "preview": true,
  "license": "MIT",
  "author": {
    "name": "SkivHisink",
    "url": "https://github.com/SkivHisink"
  },
  "homepage": "https://github.com/SkivHisink/winforms-designer-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkivHisink/winforms-designer-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/SkivHisink/winforms-designer-vscode/issues"
  },
  "qna": "https://github.com/SkivHisink/winforms-designer-vscode/issues",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#2D2D30",
    "theme": "dark"
  },
  "keywords": [
    "winforms",
    "windows forms",
    "c#",
    "csharp",
    "designer",
    "form designer",
    "ui designer",
    "visual designer",
    "gui",
    "forms",
    ".net",
    "dotnet",
    "net9",
    "wysiwyg",
    "drag and drop"
  ],
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Rendering a designer loads and executes the project's control assemblies (constructors / OnPaint run on preview), so the extension is disabled in untrusted workspaces."
    }
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "winformsDesigner.designer",
        "displayName": "WinForms Designer",
        "selector": [
          {
            "filenamePattern": "*.cs"
          }
        ],
        "priority": "option"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "winformsDesigner",
          "title": "WinForms Designer",
          "icon": "media/winforms-activity.svg"
        }
      ]
    },
    "views": {
      "winformsDesigner": [
        {
          "type": "webview",
          "id": "winformsDesigner.panel",
          "name": "Designer"
        }
      ]
    },
    "configurationDefaults": {
      "explorer.fileNesting.enabled": true,
      "explorer.fileNesting.patterns": {
        "*.cs": "${capture}.Designer.cs, ${capture}.resx, ${capture}.*.cs"
      }
    },
    "commands": [
      {
        "command": "winformsDesigner.open",
        "title": "WinForms: Open Designer"
      },
      {
        "command": "winformsDesigner.viewCode",
        "title": "WinForms: View Code"
      },
      {
        "command": "winformsDesigner.showProperties",
        "title": "WinForms: Show Properties"
      },
      {
        "command": "winformsDesigner.exportDiagnostics",
        "title": "WinForms: Export Designer Diagnostics"
      },
      {
        "command": "winformsDesigner.selectControlAssembly",
        "title": "WinForms: Select Control Assembly / Project…",
        "icon": "$(package)"
      }
    ],
    "keybindings": [
      {
        "command": "winformsDesigner.showProperties",
        "key": "f4",
        "when": "activeCustomEditorId == winformsDesigner.designer"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "winformsDesigner.open",
          "when": "winformsDesigner.canOpen"
        },
        {
          "command": "winformsDesigner.viewCode",
          "when": "activeCustomEditorId == winformsDesigner.designer"
        },
        {
          "command": "winformsDesigner.selectControlAssembly",
          "when": "activeCustomEditorId == winformsDesigner.designer"
        }
      ],
      "editor/title": [
        {
          "command": "winformsDesigner.open",
          "when": "winformsDesigner.canOpen",
          "group": "navigation"
        },
        {
          "command": "winformsDesigner.viewCode",
          "when": "activeCustomEditorId == winformsDesigner.designer",
          "group": "navigation"
        },
        {
          "command": "winformsDesigner.selectControlAssembly",
          "when": "activeCustomEditorId == winformsDesigner.designer",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "WinForms Designer",
      "properties": {
        "winformsDesigner.autoOpenDesigner": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "markdownDescription": "Automatically open the WinForms designer when a form's `.cs` (one that has a generated `.Designer.cs` partner) becomes the active editor — mirroring Visual Studio, where opening `Form1.cs` shows the designer. Use **View Code** to switch a form back to its `.cs` text (auto-open won't re-hijack it until you reopen the file). Disable this to keep the C# text editor and open the designer manually via **WinForms: Open Designer** or *Reopen Editor With…*."
        },
        "winformsDesigner.assemblyPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Explicit path to the project's built control assembly (`.dll`) used to resolve custom/3rd-party controls. Leave empty to auto-discover the project's build output. Set this only when auto-discovery fails (e.g. multi-target, a custom `OutputPath`, or a not-yet-built project).\n\n- A leading `~` expands to your home directory; a relative path resolves against the workspace folder (or the file's own directory when no folder is open). Environment variables (`%VAR%`, `${env:VAR}`, `$VAR`) are **not** expanded.\n- If the resolved path does not exist, a warning is shown and auto-discovery is used instead.\n- **The assembly is loaded and its control constructors / `OnPaint` run when a designer is previewed**, so it is honored only in a trusted workspace."
        }
      }
    }
  },
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit",
    "e2e": "node dist/e2e.cjs",
    "bundle-engine": "dotnet publish ../engine -c Release -o engine",
    "copy-license": "node -e \"require('fs').copyFileSync('../LICENSE','LICENSE')\"",
    "copy-changelog": "node -e \"require('fs').copyFileSync('../CHANGELOG.md','CHANGELOG.md')\"",
    "vscode:prepublish": "npm run build && npm run bundle-engine && npm run copy-license && npm run copy-changelog"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "vscode-jsonrpc": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.4.0"
  }
}
