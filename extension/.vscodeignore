# Everything here is excluded from the packaged .vsix.
# The extension ships only the bundled output + media + manifest/docs.

.vscode/**
.vscode-test/**
.dotnet-home/**
.dotnet-temp/**
.npm-cache*/**
src/**
tmp/**
node_modules/**

# Build tooling / config
build.mjs
tsconfig.json
**/tsconfig.json
.gitignore
.eslintrc*
*.map
dist/*e2e.cjs
dist/extension-host-suite.cjs
dist/**/*.map

# Tests / scratch
**/*.test.*
e2e-render.png
bash.exe.stackdump
**/*.log
.claude/**
*.vsix

# Bundled engines (published into engine/ + engine-net48/ at package time) — ship the runtime, not debug symbols
engine/**/*.pdb
engine/**/*.xml
engine-net48/**/*.pdb
engine-net48/**/*.xml

# Source control noise
.github/**
**/.DS_Store
