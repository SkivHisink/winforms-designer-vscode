        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#2E7D32&quot;&gt;■&lt;/font&gt; shipped&lt;br&gt;&lt;font color=&quot;#d6b656&quot;&gt;■&lt;/font&gt; current / headline 1.x milestone&lt;br&gt;&lt;font color=&quot;#6c8ebf&quot;&gt;■&lt;/font&gt; planned 1.x minor&lt;br&gt;&lt;font color=&quot;#9673a6&quot;&gt;■&lt;/font&gt; 2.0 major architecture&lt;br&gt;&lt;br&gt;&lt;b&gt;Priority rule:&lt;/b&gt; security, data-loss prevention, and stable-workflow regressions may move roadmap features between minors. Version boxes describe exit outcomes, not dates." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="1240" y="1080" width="270" height="250" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
